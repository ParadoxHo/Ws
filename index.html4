<!DOCTYPE html>
<html lang="pl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>Alarmonix | Monitoring | Alarmy | CCTV Polska</title>
  <meta name="description" content="Alarmonix - monitoring, alarmy, CCTV oraz kontrola dostępu. Katowice i cała Polska. Darmowa wycena.">
  <!-- Open Graph / Facebook -->
  <meta property="og:type" content="website">
  <meta property="og:title" content="Alarmonix | Monitoring, alarmy, CCTV">
  <meta property="og:description" content="Profesjonalne systemy bezpieczeństwa">
  <meta property="og:image" content="images/monitoring1.webp">
  <meta property="og:url" content="https://alarmonix.pl">
  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image">
  <!-- Structured Data (JSON-LD) -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "Alarmonix",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Katowice",
      "streetAddress": "ul. Przykładowa 10",
      "addressCountry": "PL"
    },
    "telephone": "+48888888888",
    "email": "alarmonix@gmail.com",
    "priceRange": "$$",
    "url": "https://alarmonix.pl"
  }
  </script>
  <!-- Preconnect i czcionki z display=swap -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <!-- Favicon (użytkownik musi dodać plik favicon.ico w katalogu głównym) -->
  <link rel="icon" type="image/x-icon" href="favicon.ico">
  <style>
    :root {
      --bg-dark: #0a0f14;
      --bg-card: #0e1620;
      --primary: #4da3ff;
      --primary-hover: #2f8cff;
      --text-light: #eaf2f9;
      --text-muted: #8ea2b6;
      --border-color: #182330;
      --border-light: #1a2633;
      --success: #22c55e;
      --whatsapp: #25d366;
      --transition: all 0.3s ease;
    }
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    body {
      background: var(--bg-dark);
      color: var(--text-light);
      font-family: 'Inter', sans-serif;
      line-height: 1.5;
    }
    html {
      scroll-behavior: smooth;
    }
    .container {
      max-width: 1350px;
      margin: 0 auto;
      padding: 0 25px;
    }
    header {
      background: #0b1117;
      border-bottom: 1px solid var(--border-light);
      position: sticky;
      top: 0;
      z-index: 1000;
    }
    .nav {
      display: flex;
      align-items: center;
      padding: 20px 0;
    }
    .logo {
      flex: 1;
    }
    .logo img {
      height: 90px;
      width: auto;
      filter: brightness(1.3) drop-shadow(0 2px 5px rgba(0,0,0,0.5));
      transition: var(--transition);
    }
    .logo img:hover {
      filter: brightness(1.6);
      transform: scale(1.02);
    }
    .nav-links {
      flex: 1;
      text-align: center;
    }
    .nav-links a {
      color: #c6d0da;
      text-decoration: none;
      font-weight: 600;
      font-size: 1.2rem;
      padding: 10px 18px;
      margin: 0 8px;
      display: inline-block;
      transition: var(--transition);
      border-radius: 8px;
      position: relative;
    }
    /* Podkreślenie dla aktywnego elementu */
    .nav-links a::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 50%;
      width: 0;
      height: 2px;
      background: var(--primary);
      transition: all 0.3s ease;
      transform: translateX(-50%);
    }
    .nav-links a:hover::after,
    .nav-links a.active::after {
      width: 70%;
    }
    .nav-links a:hover, .nav-links a.active {
      color: var(--primary);
      background: rgba(77, 163, 255, 0.1);
    }
    .menu-toggle {
      display: none;
      background: none;
      border: none;
      font-size: 28px;
      color: var(--text-light);
      cursor: pointer;
    }
    .hero {
      padding: 160px 20px;
      background: radial-gradient(circle at 10% 30%, #13202e, var(--bg-dark));
      text-align: left;
    }
    .hero h1 {
      font-size: 58px;
      margin-bottom: 25px;
      max-width: 900px;
      font-weight: 800;
      line-height: 1.2;
    }
    .hero p {
      color: var(--text-muted);
      font-size: 20px;
      margin-bottom: 40px;
      max-width: 700px;
    }
    .btn {
      background: var(--primary);
      padding: 18px 38px;
      border-radius: 12px;
      text-decoration: none;
      color: white;
      font-weight: 600;
      display: inline-block;
      transition: var(--transition);
      border: none;
      cursor: pointer;
    }
    .btn:hover {
      background: var(--primary-hover);
      transform: translateY(-3px);
      box-shadow: 0 10px 20px rgba(77, 163, 255, 0.2);
    }
    /* Mikroanimacja dla przycisków i linków */
    a, button, .float-btn {
      transition: transform 0.2s, background 0.2s, box-shadow 0.2s;
    }
    a:hover, button:hover {
      transform: translateY(-2px);
    }
    .section {
      padding: 100px 0;
    }
    .section h2 {
      font-size: 40px;
      margin-bottom: 20px;
      font-weight: 700;
    }
    .muted {
      color: var(--text-muted);
    }
    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 30px;
      margin-top: 50px;
      overflow: visible;
    }
    /* Karty z lepszą animacją – delikatne skalowanie bez rozjeżdżania */
    .card {
      background: var(--bg-card);
      padding: 35px;
      border-radius: 18px;
      border: 1px solid var(--border-color);
      transition: var(--transition);
      cursor: pointer;
      position: relative;
      overflow: visible;
      will-change: transform;
      transform-origin: center center;
    }
    .card:hover {
      border-color: var(--primary);
      transform: translateY(-6px);
      box-shadow: 0 20px 30px -15px rgba(0,0,0,0.3);
    }
    .card-icon {
      font-size: 40px;
      color: var(--primary);
      margin-bottom: 20px;
      transition: transform 0.2s;
    }
    .card:hover .card-icon {
      transform: scale(1.1);
    }
    .card h3 {
      margin-bottom: 15px;
      font-size: 24px;
    }
    .card.expanded {
      transform: scale(1.02);
      border-color: var(--primary);
      box-shadow: 0 25px 35px -12px rgba(77, 163, 255, 0.3);
      background: linear-gradient(145deg, #101a24, #0b1117);
      z-index: 10;
    }
    .card-details {
      display: none;
      margin-top: 20px;
      padding-top: 20px;
      border-top: 1px solid var(--border-color);
      color: var(--text-muted);
      font-size: 0.95rem;
      line-height: 1.5;
    }
    .card.expanded .card-details {
      display: block;
      animation: fadeSlideUp 0.4s ease;
    }
    @keyframes fadeSlideUp {
      from {
        opacity: 0;
        transform: translateY(10px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
    /* Galeria – dodane width/height */
    .gallery img {
      width: 100%;
      height: auto;
      border-radius: 14px;
      border: 1px solid var(--border-color);
      transition: var(--transition);
      aspect-ratio: 16 / 9;
      object-fit: cover;
    }
    .gallery img:hover {
      transform: scale(1.02);
      border-color: var(--primary);
    }
    .faq-item {
      padding: 20px;
      border-bottom: 1px solid var(--border-color);
    }
    .faq-item h3 {
      margin-bottom: 10px;
      font-size: 20px;
    }
    .contact {
      background: #0b1117;
      border-top: 1px solid var(--border-color);
    }
    form {
      display: grid;
      gap: 18px;
      max-width: 550px;
      margin-top: 30px;
    }
    input, textarea {
      padding: 16px;
      background: var(--bg-dark);
      border: 1px solid var(--border-color);
      border-radius: 10px;
      color: white;
      font-size: 16px;
      transition: var(--transition);
    }
    input:focus, textarea:focus {
      outline: none;
      border-color: var(--primary);
      box-shadow: 0 0 0 2px rgba(77, 163, 255, 0.2);
    }
    button {
      background: var(--primary);
      border: none;
      padding: 18px;
      border-radius: 12px;
      color: white;
      font-weight: 600;
      font-size: 16px;
      cursor: pointer;
      transition: var(--transition);
    }
    button:hover {
      background: var(--primary-hover);
      transform: translateY(-2px);
    }
    footer {
      border-top: 1px solid var(--border-color);
      padding: 30px 0;
      color: var(--text-muted);
      text-align: center;
    }
    /* Pływające przyciski – na mobile poziomo */
    .float-buttons {
      position: fixed;
      bottom: 25px;
      right: 25px;
      display: flex;
      flex-direction: column;
      gap: 15px;
      z-index: 999;
    }
    .float-btn {
      width: 60px;
      height: 60px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 26px;
      color: white;
      text-decoration: none;
      transition: var(--transition);
      box-shadow: 0 4px 10px rgba(0,0,0,0.3);
    }
    .float-btn:hover {
      transform: scale(1.1);
    }
    .email-btn { background: var(--primary); }
    .call-btn { background: var(--success); }
    .whatsapp-btn { background: var(--whatsapp); }

    /* Banner ciasteczek (RODO) */
    .cookie-banner {
      position: fixed;
      bottom: 0;
      left: 0;
      width: 100%;
      background: #0b1117;
      border-top: 1px solid var(--primary);
      padding: 15px 20px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 15px;
      z-index: 1100;
      font-size: 14px;
    }
    .cookie-banner p {
      margin: 0;
      color: var(--text-muted);
    }
    .cookie-banner button {
      background: var(--primary);
      border: none;
      padding: 8px 20px;
      border-radius: 30px;
      color: white;
      cursor: pointer;
      font-weight: 600;
    }
    .cookie-banner button:hover {
      background: var(--primary-hover);
    }

    /* Modal polityki prywatności */
    .modal {
      display: none;
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: rgba(0,0,0,0.8);
      z-index: 2000;
      justify-content: center;
      align-items: center;
    }
    .modal-content {
      background: #0e1620;
      border: 1px solid var(--primary);
      border-radius: 24px;
      max-width: 800px;
      max-height: 85vh;
      overflow-y: auto;
      padding: 30px;
      position: relative;
      margin: 20px;
      color: var(--text-light);
      box-shadow: 0 20px 40px rgba(0,0,0,0.5);
    }
    .modal-content h2 {
      font-size: 28px;
      margin-bottom: 20px;
      color: var(--primary);
    }
    .modal-content h3 {
      font-size: 20px;
      margin: 20px 0 10px;
      color: #c6d0da;
    }
    .modal-content p, .modal-content li {
      font-size: 15px;
      line-height: 1.5;
      margin-bottom: 10px;
      color: var(--text-muted);
    }
    .modal-content ul {
      margin-left: 20px;
      margin-bottom: 15px;
    }
    .close-modal {
      position: absolute;
      top: 15px;
      right: 20px;
      font-size: 28px;
      cursor: pointer;
      color: var(--text-muted);
      transition: var(--transition);
    }
    .close-modal:hover {
      color: var(--primary);
    }

    /* Responsywność */
    @media (max-width: 992px) {
      .hero h1 { font-size: 48px; }
      .section h2 { font-size: 32px; }
    }
    @media (max-width: 768px) {
      .menu-toggle {
        display: block;
      }
      .nav {
        justify-content: space-between;
      }
      .logo {
        flex: none;
      }
      .logo img {
        height: 45px;
      }
      .nav-links {
        display: none;
        flex: none;
        position: absolute;
        top: 80px;
        left: 0;
        width: 100%;
        background: #0b1117;
        border-bottom: 1px solid var(--border-color);
        padding: 20px;
        gap: 20px;
        text-align: center;
      }
      .nav-links.show {
        display: flex;
        flex-direction: column;
      }
      .nav-links a {
        display: block;
        margin: 5px 0;
        font-size: 1.1rem;
      }
      .nav-links a::after {
        display: none;
      }
      .hero {
        padding: 100px 20px;
      }
      .hero h1 {
        font-size: 36px;
      }
      .hero p {
        font-size: 18px;
      }
      /* Pływające przyciski – poziomo na dole */
      .float-buttons {
        flex-direction: row;
        bottom: 15px;
        right: 15px;
        gap: 12px;
      }
      .float-btn {
        width: 50px;
        height: 50px;
        font-size: 22px;
      }
      .grid {
        gap: 20px;
      }
      .card {
        padding: 25px;
      }
      .card.expanded {
        transform: scale(1.02);
      }
      .cookie-banner {
        flex-direction: column;
        text-align: center;
        padding: 12px;
      }
    }
    @media (max-width: 480px) {
      .container {
        padding: 0 20px;
      }
      .hero h1 {
        font-size: 28px;
      }
      .btn {
        padding: 14px 28px;
      }
    }
    a:focus-visible, button:focus-visible, input:focus-visible, textarea:focus-visible {
      outline: 2px solid var(--primary);
      outline-offset: 2px;
    }
  </style>
</head>
<body>
  <header>
    <div class="container nav">
      <div class="logo">
        <img src="logo.png" alt="Alarmonix">
      </div>
      <button class="menu-toggle" aria-label="Menu" aria-expanded="false">
        <i class="fas fa-bars"></i>
      </button>
      <nav class="nav-links" aria-label="Główna nawigacja">
        <a href="#services">Usługi</a>
        <a href="#projects">Realizacje</a>
        <a href="#faq">FAQ</a>
        <a href="#contact">Kontakt</a>
      </nav>
    </div>
  </header>

  <main>
    <section class="hero">
      <div class="container">
        <h1>Profesjonalne systemy bezpieczeństwa</h1>
        <p>Monitoring CCTV, systemy alarmowe oraz kontrola dostępu.</p>
        <a class="btn" href="#contact">Darmowa wycena <i class="fas fa-arrow-right"></i></a>
      </div>
    </section>

    <section class="section" id="services">
      <div class="container">
        <h2>Usługi</h2>
        <div class="grid">
          <div class="card">
            <div class="card-icon"><i class="fas fa-video"></i></div>
            <h3>Monitoring CCTV</h3>
            <p class="muted">Instalacja kamer IP, analogowych oraz rejestratorów z analityką.</p>
            <div class="card-details">
              Oferujemy profesjonalny monitoring CCTV z kamerami o wysokiej rozdzielczości, nocną wizją, detekcją ruchu i zdalnym podglądem przez aplikację. Rejestratory z funkcją analityki AI, nagrywanie w chmurze i lokalnie.
            </div>
          </div>
          <div class="card">
            <div class="card-icon"><i class="fas fa-bell"></i></div>
            <h3>Systemy alarmowe</h3>
            <p class="muted">Bezprzewodowe i przewodowe systemy antywłamaniowe.</p>
            <div class="card-details">
              Systemy alarmowe – bezprzewodowe i przewodowe, z powiadomieniami push, syrenami zewnętrznymi i integracją z monitoringiem. Sterowanie przez aplikację, monitoring 24/7.
            </div>
          </div>
          <div class="card">
            <div class="card-icon"><i class="fas fa-id-card"></i></div>
            <h3>Kontrola dostępu</h3>
            <p class="muted">Systemy RFID, czytniki biometryczne, elektrozaczepy.</p>
            <div class="card-details">
              Kontrola dostępu RFID, czytniki kart, kody PIN, biometria odcisków palców. Zdalne zarządzanie uprawnieniami, logowanie wejść i wyjść, integracja z systemami rejestracji czasu pracy.
            </div>
          </div>
          <div class="card">
            <div class="card-icon"><i class="fas fa-phone-alt"></i></div>
            <h3>Wideodomofony</h3>
            <p class="muted">Nowoczesne instalacje z aplikacją mobilną.</p>
            <div class="card-details">
              Nowoczesne wideodomofony z kolorowym ekranem dotykowym, aplikacją mobilną, możliwością otwierania bramy i furtki z telefonu. Obsługa wielu użytkowników, nagrywanie zdarzeń.
            </div>
          </div>
          <div class="card">
            <div class="card-icon"><i class="fas fa-tools"></i></div>
            <h3>Serwis</h3>
            <p class="muted">Modernizacje, naprawy i przeglądy systemów.</p>
            <div class="card-details">
              Przeglądy, konserwacja, naprawy systemów bezpieczeństwa. Szybka interwencja, umowy serwisowe, modernizacja przestarzałych instalacji do najnowszych standardów.
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section" id="projects">
      <div class="container">
        <h2>Realizacje</h2>
        <p class="muted">Przykładowe obiekty.</p>
        <div class="grid gallery">
          <img src="images/monitoring1.webp" alt="Monitoring biura" width="600" height="400" loading="lazy">
          <img src="images/monitoring2.webp" alt="Kamery na zewnątrz budynku" width="600" height="400" loading="lazy">
          <img src="images/monitoring3.webp" alt="Centrum kontroli dostępu" width="600" height="400" loading="lazy">
        </div>
      </div>
    </section>

    <section class="section" id="faq">
      <div class="container">
        <h2>FAQ</h2>
        <div class="faq">
          <div class="faq-item">
            <h3>Ile kosztuje?</h3>
            <p class="muted">Wycena jest darmowa. Cena zależy od indywidualnych potrzeb. Skontaktuj się z nami, aby uzyskać ofertę.</p>
          </div>
          <div class="faq-item">
            <h3>Czas realizacji?</h3>
            <p class="muted">Zazwyczaj od jednego dnia w zależności od skali projektu.</p>
          </div>
          <div class="faq-item">
            <h3>Obszar działania?</h3>
            <p class="muted">Cała Polska – realizujemy zlecenia zarówno lokalnie, jak i ogólnokrajowo.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="section contact" id="contact">
      <div class="container">
        <h2>Kontakt</h2>
        <form id="contact-form" action="https://formspree.io/f/xeqdknge" method="POST">
          <input type="text" name="name" placeholder="Imię i nazwisko" required>
          <input type="tel" name="phone" placeholder="Telefon" required>
          <input type="email" name="email" placeholder="Email">
          <textarea name="message" rows="5" placeholder="Opisz projekt" required></textarea>
          <button type="submit">Wyślij wiadomość</button>
          <p id="form-status" class="muted" style="margin-top: 10px;"></p>
        </form>
        <div style="margin-top:40px" class="muted">
          <p><b>Alarmonix</b></p>
          <p>Katowice, ul. Przykładowa 10</p>
          <p><i class="fas fa-phone-alt"></i> +48 888 888 888</p>
          <p><i class="fas fa-envelope"></i> alarmonix@gmail.com</p>
          <p>Obsługa firm i klientów prywatnych</p>
        </div>
      </div>
    </section>
  </main>

  <footer>
    <div class="container">
      <p>© 2026 Alarmonix | <a href="#" id="openPrivacyBtn" style="color: var(--text-muted);">Polityka prywatności</a> | <a href="#" id="openRodoBtn" style="color: var(--text-muted);">RODO</a></p>
    </div>
  </footer>

  <div class="float-buttons">
    <a class="float-btn email-btn" href="mailto:alarmonix@gmail.com" aria-label="Wyślij e-mail"><i class="fas fa-envelope"></i></a>
    <a class="float-btn call-btn" href="tel:+48888888888" aria-label="Zadzwoń"><i class="fas fa-phone-alt"></i></a>
    <a class="float-btn whatsapp-btn" href="https://wa.me/48888888888" aria-label="WhatsApp"><i class="fab fa-whatsapp"></i></a>
  </div>

  <!-- Banner cookies -->
  <div id="cookieBanner" class="cookie-banner" style="display: none;">
    <p>Ta strona używa plików cookies w celu zapewnienia wygody i analizy ruchu. Klikając „Akceptuję”, wyrażasz zgodę na ich użycie.</p>
    <button id="acceptCookies">Akceptuję</button>
  </div>

  <!-- Modal Polityki Prywatności -->
  <div id="privacyModal" class="modal">
    <div class="modal-content">
      <span class="close-modal">&times;</span>
      <h2>Polityka prywatności i RODO</h2>
      <p>Dbamy o Twoją prywatność. Poniżej znajdziesz szczegółowe informacje dotyczące przetwarzania danych osobowych oraz plików cookies.</p>
      <h3>Administrator danych</h3>
      <p>Administratorem Twoich danych osobowych jest <strong>Alarmonix</strong> z siedzibą w Katowicach, ul. Przykładowa 10. Kontakt: <strong>alarmonix@gmail.com</strong>, tel. +48 888 888 888.</p>
      <h3>Jakie dane zbieramy i w jakim celu?</h3>
      <p>W ramach strony zbieramy dane osobowe w następujących celach:</p>
      <ul>
        <li><strong>Kontakt przez formularz</strong> – imię i nazwisko, numer telefonu, adres e-mail oraz treść wiadomości. Podstawą przetwarzania jest Twoja zgoda (art. 6 ust. 1 lit. a RODO) oraz niezbędność do podjęcia działań na Twoje żądanie (art. 6 ust. 1 lit. b RODO).</li>
        <li><strong>Analityka strony</strong> – korzystamy z plików cookies w celu poprawy działania strony i analizy ruchu (na podstawie art. 6 ust. 1 lit. f RODO – prawnie uzasadniony interes administratora).</li>
      </ul>
      <h3>Okres przechowywania danych</h3>
      <p>Dane z formularza kontaktowego przechowujemy przez okres niezbędny do udzielenia odpowiedzi, a następnie przez czas przedawnienia ewentualnych roszczeń (maksymalnie 3 lata). Dane analityczne (cookies) są przechowywane zgodnie z polityką poszczególnych plików (szczegóły poniżej).</p>
      <h3>Odbiorcy danych</h3>
      <p>Twoje dane nie są sprzedawane ani udostępniane przypadkowym podmiotom. Mogą być przekazywane wyłącznie podmiotom upoważnionym na podstawie przepisów prawa lub dostawcom usług technicznych (np. hosting, usługi poczty elektronicznej).</p>
      <h3>Prawa osób, których dane dotyczą</h3>
      <p>Przysługują Ci następujące prawa:</p>
      <ul>
        <li>dostępu do swoich danych,</li>
        <li>sprostowania (poprawiania) danych,</li>
        <li>usunięcia danych („prawo do bycia zapomnianym”),</li>
        <li>ograniczenia przetwarzania,</li>
        <li>przenoszenia danych,</li>
        <li>wniesienia sprzeciwu wobec przetwarzania,</li>
        <li>cofnięcia zgody w dowolnym momencie (bez wpływu na zgodność przetwarzania przed jej cofnięciem).</li>
      </ul>
      <p>W celu realizacji swoich praw skontaktuj się z nami przez e-mail: <strong>alarmonix@gmail.com</strong>. Masz także prawo wniesienia skargi do Prezesa Urzędu Ochrony Danych Osobowych (PUODO).</p>
      <h3>Pliki cookies (ciasteczka)</h3>
      <p>Strona internetowa Alarmonix używa plików cookies w celu:</p>
      <ul>
        <li>zapewnienia prawidłowego działania strony (niezbędne cookies),</li>
        <li>analizy statystyk i zachowań użytkowników (analityczne cookies – np. Google Analytics, jeżeli zostaną wdrożone).</li>
      </ul>
      <p>Większość przeglądarek internetowych pozwala na zarządzanie plikami cookies – możesz blokować je lub usuwać. Szczegółowe informacje znajdują się w ustawieniach Twojej przeglądarki. Korzystanie ze strony bez zmiany ustawień oznacza akceptację stosowanych plików cookies.</p>
      <h3>Podstawy prawne przetwarzania</h3>
      <p>Przetwarzanie danych odbywa się zgodnie z Rozporządzeniem Parlamentu Europejskiego i Rady (UE) 2016/679 (RODO) oraz ustawą Prawo telekomunikacyjne. W sprawach nieuregulowanych polityką prywatności stosuje się przepisy powszechnie obowiązującego prawa.</p>
      <p><em>Polityka prywatności jest aktualna na dzień 9 kwietnia 2026 r. W razie pytań zapraszamy do kontaktu.</em></p>
    </div>
  </div>

  <script>
    (function() {
      // Mobile menu toggle
      const menuToggle = document.querySelector('.menu-toggle');
      const navLinks = document.querySelector('.nav-links');
      if (menuToggle && navLinks) {
        menuToggle.addEventListener('click', () => {
          const expanded = menuToggle.getAttribute('aria-expanded') === 'true' ? false : true;
          menuToggle.setAttribute('aria-expanded', expanded);
          navLinks.classList.toggle('show');
        });
        navLinks.querySelectorAll('a').forEach(link => {
          link.addEventListener('click', () => {
            navLinks.classList.remove('show');
            menuToggle.setAttribute('aria-expanded', false);
          });
        });
      }

      // Active menu item on scroll (z podkreśleniem)
      const sections = document.querySelectorAll('section[id]');
      const navItems = document.querySelectorAll('.nav-links a');
      function setActive() {
        let scrollPos = window.scrollY + 150;
        sections.forEach(section => {
          const top = section.offsetTop;
          const bottom = top + section.offsetHeight;
          if (scrollPos >= top && scrollPos < bottom) {
            const id = section.getAttribute('id');
            navItems.forEach(item => {
              item.classList.remove('active');
              if (item.getAttribute('href') === `#${id}`) {
                item.classList.add('active');
              }
            });
          }
        });
      }
      window.addEventListener('scroll', setActive);
      setActive();

      // Form handling z Formspree (rzeczywiste wysyłanie)
      const form = document.getElementById('contact-form');
      const formStatus = document.getElementById('form-status');
      if (form) {
        form.addEventListener('submit', async (e) => {
          e.preventDefault();
          formStatus.textContent = 'Wysyłanie...';
          formStatus.style.color = '#4da3ff';
          try {
            const response = await fetch(form.action, {
              method: 'POST',
              body: new FormData(form),
              headers: { 'Accept': 'application/json' }
            });
            if (response.ok) {
              formStatus.textContent = 'Dziękujemy! Skontaktujemy się wkrótce.';
              form.reset();
            } else {
              formStatus.textContent = 'Błąd. Spróbuj ponownie lub napisz bezpośrednio na email.';
            }
          } catch (error) {
            formStatus.textContent = 'Błąd połączenia. Spróbuj później.';
          }
        });
      }

      // Expandable cards (ulepszona animacja)
      const cards = document.querySelectorAll('.card');
      cards.forEach(card => {
        card.addEventListener('click', (e) => {
          e.stopPropagation();
          if (card.classList.contains('expanded')) {
            card.classList.remove('expanded');
          } else {
            cards.forEach(c => c.classList.remove('expanded'));
            card.classList.add('expanded');
          }
        });
      });

      // Modal for Privacy Policy / RODO
      const modal = document.getElementById('privacyModal');
      const openBtns = document.querySelectorAll('#openPrivacyBtn, #openRodoBtn');
      const closeBtn = document.querySelector('.close-modal');
      function openModal() { modal.style.display = 'flex'; }
      function closeModal() { modal.style.display = 'none'; }
      openBtns.forEach(btn => {
        btn.addEventListener('click', (e) => {
          e.preventDefault();
          openModal();
        });
      });
      closeBtn.addEventListener('click', closeModal);
      window.addEventListener('click', (e) => {
        if (e.target === modal) closeModal();
      });

      // Cookie banner (RODO)
      const cookieBanner = document.getElementById('cookieBanner');
      const acceptBtn = document.getElementById('acceptCookies');
      if (!localStorage.getItem('cookiesAccepted')) {
        cookieBanner.style.display = 'flex';
      }
      acceptBtn.addEventListener('click', () => {
        localStorage.setItem('cookiesAccepted', 'true');
        cookieBanner.style.display = 'none';
      });
    })();
  </script>
</body>
</html>
